# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#

# =============== #
#      Unity      #
# =============== #

.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Crash Reports
sysinfo.txt

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
mono_crash.*

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln

# Exception: hand-authored .NET projects/solution (not Unity-generated ones)
!/Molecularity.sln
!src/**/*.csproj
!tests/**/*.csproj
!tools/**/*.csproj

# .NET build output (any project depth)
[Bb]in/
[Oo]bj/
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# TestRunner generated files
InitTestScene*.unity*

# Auto-generated scenes by play mode tests
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Addressables
/[Ss]erver[Dd]ata/
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa.meta
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa/*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/[Ww]indows/
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/[Aa]ndroid/
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/[ii][Oo][Ss]/
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/link.xml*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Aa]ddressables_[Tt]emp*

# Visual Scripting auto-generated files
/[Aa]ssets/Unity.VisualScripting.Generated/

# TextMesh Pro
/[Aa]ssets/TextMesh Pro/

# =============== #
#      Builds     #
# =============== #

*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.dll
!Assets/**/*.dll

# =============== #
#   JetBrains     #
#      Rider      #
# =============== #

# Rider IDE
.idea/
*.sln.iml

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Rider code inspection
[Aa]ssembly-CSharp*.csproj.DotSettings

# =============== #
#  Visual Studio  #
# =============== #

.vs/
*.vcxproj
*.vcxproj.filters

# =============== #
#      Gradle     #
# =============== #

.gradle/
**/build/
!**/src/**/build/

# =============== #
#     Blender     #
# =============== #

*.blend1
*.blend1.meta

# =============== #
#   Crashlytics   #
# =============== #

crashlytics-build.properties

# =============== #
#       OS        #
# =============== #

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# =============== #
#      Other      #
# =============== #

# Plastic SCM
.plastic/
.plastic*

# NuGet
*.nupkg
packages/
NuGet.config

# Code coverage
*.coverage
*.coveragexml
coverage/
